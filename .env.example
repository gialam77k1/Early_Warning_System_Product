# ============================================================
#  Sao chép file này thành .env và điền thông tin thực tế
#  cp .env.example .env
# ============================================================

# Database PostgreSQL
DB_NAME=early_warning_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost        # Dùng "db" khi chạy Docker
DB_PORT=5432

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://localhost:5050   # Dùng "http://mlflow:5000" khi chạy Docker

# Django Secret Key (thay bằng key ngẫu nhiên khi deploy production)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=your-secret-key-here

# Django Debug (đặt False khi deploy production)
# DEBUG=True
